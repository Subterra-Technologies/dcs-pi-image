#!/usr/bin/env bash
# First-boot enrollment for a Subterra Pi (Tailscale SaaS).
#
# Reads the pre-auth key from /boot/firmware/subterra-enroll.json, joins
# the Tailscale tailnet, advertises the district's school-LAN subnets.
# Routes auto-approve via the tailnet ACL's autoApprovers (RFC1918 for
# tag:pi-*). No raw WireGuard, no NETMAP, no MASQUERADE — Tailscale's
# subnet router feature + ACL handle all of that.
#
# The key must be tagged appropriately (e.g. tag:pi-district-a) when
# created in the Tailscale admin console; the tag governs what routes the
# Pi can advertise and what district Zabbix can reach it.
set -euo pipefail

STATE_DIR="${SUBTERRA_STATE_DIR:-/var/lib/subterra}"
ENROLL_CONFIG="${SUBTERRA_ENROLL_CONFIG:-/boot/firmware/subterra-enroll.json}"
DRY_RUN="${SUBTERRA_DRY_RUN:-0}"

ENROLL_SENTINEL="${STATE_DIR}/enrolled"
ENROLL_META="${STATE_DIR}/enrollment.json"

LOG_TAG=subterra-enroll
log() { printf '%s: %s\n' "${LOG_TAG}" "$*" >&2; }
die() { log "FATAL: $*"; exit 1; }
priv() {
    if [[ "${DRY_RUN}" = "1" ]]; then
        log "DRY: $*"
    else
        "$@"
    fi
}

if [[ -f "${ENROLL_SENTINEL}" ]]; then
    log "already enrolled, exiting"
    exit 0
fi

mkdir -p "${STATE_DIR}"

[[ -f "${ENROLL_CONFIG}" ]] || die "no enrollment config at ${ENROLL_CONFIG}"

AUTHKEY="$(jq -r '.authkey // empty' "${ENROLL_CONFIG}")"
LOGIN_SERVER="$(jq -r '.login_server // empty' "${ENROLL_CONFIG}")"
DISTRICT="$(jq -r '.district // empty' "${ENROLL_CONFIG}")"
ADVERTISE_ROUTES="$(jq -r '.advertise_routes // [] | join(",")' "${ENROLL_CONFIG}")"
HOSTNAME_HINT="$(jq -r '.hostname // empty' "${ENROLL_CONFIG}")"

[[ -n "${AUTHKEY}" ]]  || die "authkey missing from ${ENROLL_CONFIG}"
[[ -n "${DISTRICT}" ]] || die "district missing from ${ENROLL_CONFIG}"
# login_server is OPTIONAL — defaults to Tailscale SaaS (controlplane.tailscale.com).
# Set it explicitly only if dialing a self-hosted Headscale.

# Auto-detect the primary subnet if ops didn't pre-seed one. Merge with
# whatever they did pre-seed.
detect_primary_subnet() {
    local iface cidr
    iface="$(ip -o -4 route show default 2>/dev/null | awk '{print $5; exit}')"
    [[ -n "${iface}" ]] || return 1
    cidr="$(ip -o -4 addr show dev "${iface}" 2>/dev/null | awk '{print $4; exit}')"
    [[ -n "${cidr}" ]] || return 1
    python3 -c "
import ipaddress, sys
print(ipaddress.ip_interface(sys.argv[1]).network.with_prefixlen)
" "${cidr}"
}

PRIMARY=""
if PRIMARY="$(detect_primary_subnet)"; then
    log "detected primary subnet: ${PRIMARY}"
fi

# Stitch detected + explicit routes into one comma-separated list.
if [[ -n "${PRIMARY}" ]]; then
    if [[ -z "${ADVERTISE_ROUTES}" ]]; then
        ADVERTISE_ROUTES="${PRIMARY}"
    elif [[ ",${ADVERTISE_ROUTES}," != *",${PRIMARY},"* ]]; then
        ADVERTISE_ROUTES="${PRIMARY},${ADVERTISE_ROUTES}"
    fi
fi
log "routes to advertise: ${ADVERTISE_ROUTES:-<none>}"

# Hostname = explicit hint, else <district>-<short-serial>
if [[ -z "${HOSTNAME_HINT}" ]]; then
    if [[ -n "${SUBTERRA_SERIAL:-}" ]]; then
        SERIAL_SHORT="${SUBTERRA_SERIAL}"
    elif [[ -r /sys/firmware/devicetree/base/serial-number ]]; then
        SERIAL_SHORT="$(tr -d '\0' < /sys/firmware/devicetree/base/serial-number | tail -c 8)"
    else
        SERIAL_SHORT="$(hostname)"
    fi
    HOSTNAME_NEW="${DISTRICT}-pi-${SERIAL_SHORT}"
else
    HOSTNAME_NEW="${HOSTNAME_HINT}"
fi
priv hostnamectl set-hostname "${HOSTNAME_NEW}"

args=(
    up
    --authkey "${AUTHKEY}"
    --hostname "${HOSTNAME_NEW}"
    --ssh
    --accept-dns=false
    --reset
)
if [[ -n "${LOGIN_SERVER}" ]]; then
    args+=(--login-server "${LOGIN_SERVER%/}")
fi
if [[ -n "${ADVERTISE_ROUTES}" ]]; then
    args+=(--advertise-routes "${ADVERTISE_ROUTES}")
fi

log "joining tailnet (${LOGIN_SERVER:-Tailscale SaaS})"
priv tailscale "${args[@]}"

# Record what we did for humans reading the Pi later.
jq -n \
    --arg hostname "${HOSTNAME_NEW}" \
    --arg district "${DISTRICT}" \
    --arg login_server "${LOGIN_SERVER:-tailscale-saas}" \
    --arg routes "${ADVERTISE_ROUTES}" \
    --arg enrolled_at "$(date -u +%FT%TZ)" \
    '{hostname:$hostname, district:$district, login_server:$login_server,
      advertise_routes:$routes, enrolled_at:$enrolled_at}' \
    > "${ENROLL_META}"

touch "${ENROLL_SENTINEL}"
rm -f "${ENROLL_CONFIG}"
sync

log "enrollment complete for ${HOSTNAME_NEW}"

if [[ "${DRY_RUN}" != "1" ]]; then
    log "rebooting to verify clean boot"
    systemctl reboot
fi
