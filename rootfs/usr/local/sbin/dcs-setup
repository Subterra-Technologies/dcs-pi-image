#!/usr/bin/env bash
# dcs-setup: interactive TUI to provision a DCS Pi before office → site deploy.
#
# Flow:
#   1. Collect district, 1+ school LAN CIDRs, hostname hint, paste tailscale authkey
#   2. Write /boot/firmware/dcs-enroll.json with explicit advertise_routes
#   3. Kick first-boot.service; dcs-enroll runs, joins tailnet, reboots
#
# After this succeeds the Pi is fully enrolled with the *school's* LAN(s) advertised,
# even though it's physically sitting in the office. Ship it; it will come online
# at the school with the same tailnet identity.

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

ENROLL_CONFIG=/boot/firmware/dcs-enroll.json
STATE_DIR=/var/lib/dcs
DCS_CONF="${DCS_CONF:-/etc/dcs.conf}"

# Palette
C_BRAND=99      # purple
C_OK=42         # green
C_WARN=214      # amber
C_ERR=196       # red
C_MUTED=245     # gray
C_INFO=75       # cyan-blue

header() {
    gum style \
        --border double --border-foreground "${C_BRAND}" \
        --padding "1 3" --margin "1 0" \
        --foreground "${C_BRAND}" --bold \
        "$@"
}
section() { gum style --foreground "${C_BRAND}" --bold --margin "1 0 0 0" "▸ $*"; }
ok()      { gum style --foreground "${C_OK}"    "✓ $*"; }
warn()    { gum style --foreground "${C_WARN}"  "⚠ $*"; }
err()     { gum style --foreground "${C_ERR}"   "✗ $*"; }
muted()   { gum style --foreground "${C_MUTED}" "$*"; }

valid_cidr() {
    [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]]
}

# Coerce a freeform string to a valid DNS label: lowercase, spaces/underscores
# → hyphens, strip other junk, collapse runs of '-', trim leading/trailing '-'.
slugify() {
    local s="${1,,}"
    s="${s// /-}"
    s="${s//_/-}"
    s="$(printf '%s' "$s" | sed -E 's/[^a-z0-9-]//g; s/-+/-/g; s/^-+|-+$//g')"
    printf '%s' "$s"
}

# Round-trip the OAuth client_credentials flow to confirm the creds currently
# loaded in the env are valid. Returns 0 if Tailscale returns an access_token.
test_oauth_creds() {
    local token
    token=$(curl -sSf -X POST https://api.tailscale.com/api/v2/oauth/token \
        -d "client_id=${DCS_TS_OAUTH_CLIENT_ID:-}" \
        -d "client_secret=${DCS_TS_OAUTH_CLIENT_SECRET:-}" \
        -d "grant_type=client_credentials" 2>/dev/null \
        | jq -r '.access_token // empty' || true)
    [[ -n "${token}" ]]
}

# Make sure ${DCS_CONF} has working OAuth client credentials. If it doesn't,
# walk the operator through entering them in the TUI and persist them. We
# validate against Tailscale's token endpoint before writing so a typo is
# caught immediately, not deep in the enrollment flow.
ensure_oauth_creds() {
    if [[ -f "${DCS_CONF}" ]]; then
        # shellcheck disable=SC1090
        . "${DCS_CONF}"
    fi
    if [[ -n "${DCS_TS_OAUTH_CLIENT_ID:-}" && -n "${DCS_TS_OAUTH_CLIENT_SECRET:-}" ]]; then
        if test_oauth_creds; then
            return 0
        fi
        warn "OAuth creds in ${DCS_CONF} are invalid — let's re-enter them."
    fi

    section "Tailscale OAuth client (one-time)"
    muted "Mint at: https://login.tailscale.com/admin/settings/oauth"
    muted "Scopes: devices:read + auth_keys:write"
    muted "Client secret starts with 'tskey-client-' (not 'tskey-auth-')."
    muted "Stored in ${DCS_CONF} (0600) so future Pis on this image skip this step."

    while true; do
        DCS_TS_OAUTH_CLIENT_ID=$(gum input --prompt "client id › " \
            --placeholder "short string, no tskey- prefix")
        if [[ -z "${DCS_TS_OAUTH_CLIENT_ID}" ]]; then
            err "client id required"
            continue
        fi
        DCS_TS_OAUTH_CLIENT_SECRET=$(gum input --password --prompt "client secret › ")
        if [[ -z "${DCS_TS_OAUTH_CLIENT_SECRET}" ]]; then
            err "client secret required"
            continue
        fi
        if test_oauth_creds; then
            ok "OAuth creds validated"
            umask 077
            cat > "${DCS_CONF}" <<EOF
# Tailscale API creds. Scopes: devices:read, auth_keys:write.
DCS_TS_OAUTH_CLIENT_ID=${DCS_TS_OAUTH_CLIENT_ID}
DCS_TS_OAUTH_CLIENT_SECRET=${DCS_TS_OAUTH_CLIENT_SECRET}
DCS_TS_TAILNET=${DCS_TS_TAILNET:--}
EOF
            chmod 0600 "${DCS_CONF}"
            export DCS_TS_OAUTH_CLIENT_ID DCS_TS_OAUTH_CLIENT_SECRET
            return 0
        fi
        err "Tailscale rejected those creds. Check the OAuth client, try again."
    done
}

header \
    "◆ SCHOOL SIDE ◆" \
    "" \
    "DCS Pi Setup" \
    "" \
    "Appliance deployed at the school — district subnet router."

if [[ -f "${STATE_DIR}/enrolled" ]]; then
    warn "This Pi is already enrolled."
    gum confirm "Re-enroll? This wipes local tailscale state." || exit 0
    tailscale logout 2>/dev/null || true
    rm -f "${STATE_DIR}/enrolled" "${STATE_DIR}/enrollment.json"
    ok "Previous state cleared."
fi

# Collect OAuth client creds up-front so the District/CIDR/Hostname sections
# can lean on dcs-query for autosuggestions, and so we can mint the auth key
# automatically at the end instead of asking the operator to paste one.
# Skippable via DCS_AUTHKEY for air-gapped / manual-paste workflows.
if [[ -z "${DCS_AUTHKEY:-}" ]]; then
    ensure_oauth_creds
fi

section "District"
DISTRICT_RAW=$(gum input --prompt "› " --placeholder "slug, e.g. oakridge (lowercase, no spaces)")
[[ -n "${DISTRICT_RAW}" ]] || { err "district required"; exit 1; }
DISTRICT="$(slugify "${DISTRICT_RAW}")"
[[ -n "${DISTRICT}" ]] || { err "district reduces to empty slug after sanitizing"; exit 1; }
if [[ "${DISTRICT}" != "${DISTRICT_RAW}" ]]; then
    warn "Sanitized to valid slug: '${DISTRICT_RAW}' → '${DISTRICT}'"
fi

section "School LAN subnets"

# If this district already has a Pi on the tailnet, inherit its advertised
# routes as defaults so redundant Pis don't drift on CIDR advertisement.
EXISTING_CIDRS=()
if command -v dcs-query >/dev/null 2>&1; then
    mapfile -t EXISTING_CIDRS < <(dcs-query cidrs "${DISTRICT}" 2>/dev/null | awk 'NF')
fi

CIDRS=()
if [[ ${#EXISTING_CIDRS[@]} -gt 0 ]]; then
    ok "Found existing Pi(s) in this district advertising:"
    for c in "${EXISTING_CIDRS[@]}"; do printf '    • %s\n' "${c}"; done
    if gum confirm "Use the same CIDRs for this Pi?"; then
        CIDRS=("${EXISTING_CIDRS[@]}")
    fi
fi

if [[ ${#CIDRS[@]} -eq 0 ]]; then
    muted "Enter each CIDR the Pi should advertise. Leave blank to finish."
    muted "If you skip entirely, auto-detect uses the primary subnet at first boot."
    while true; do
        if [[ ${#CIDRS[@]} -eq 0 ]]; then
            placeholder="e.g. 10.42.0.0/24  (blank → auto-detect at boot)"
        else
            placeholder="another CIDR, or blank to finish (${#CIDRS[@]} added)"
        fi
        CIDR=$(gum input --prompt "› " --placeholder "${placeholder}")
        [[ -z "${CIDR}" ]] && break
        if ! valid_cidr "${CIDR}"; then
            err "invalid CIDR: ${CIDR}"
            continue
        fi
        CIDRS+=("${CIDR}")
        ok "added ${CIDR}"
    done
fi

if [[ ${#CIDRS[@]} -eq 0 ]]; then
    warn "No CIDR entered — will auto-detect the primary subnet at first boot."
    warn "If you're shipping this Pi office → school, cancel and enter the school's CIDR now."
    gum confirm "Continue without explicit CIDRs?" || { warn "aborted"; exit 1; }
fi

section "Hostname"

# Suggest the next letter by inspecting existing <slug>-pi-<letter> hostnames.
# Falls back to serial-based default if API unavailable or no prior Pi.
SUGGESTED_HOSTNAME=""
if command -v dcs-query >/dev/null 2>&1; then
    # `|| true` so a dcs-query failure (no /etc/dcs.conf, bad OAuth, offline)
    # falls back to serial-based hostname instead of killing the script under
    # `set -e` + `pipefail`.
    hostnames=$(dcs-query hostnames "tag:pi-${DISTRICT}" 2>/dev/null || true)
    letters=$(printf '%s\n' "${hostnames}" \
        | sed -nE "s/^${DISTRICT}-pi-([a-z])$/\1/p" \
        | sort -u)
    if [[ -n "${letters}" ]]; then
        last=$(printf '%s\n' "${letters}" | tail -1)
        next=$(printf '%s' "${last}" | tr 'a-y' 'b-z')
        [[ "${next}" == "${last}" ]] && next=z
        SUGGESTED_HOSTNAME="${DISTRICT}-pi-${next}"
    elif [[ -n "${hostnames}" ]]; then
        # Existing Pi(s) but none with a letter suffix — start the convention.
        SUGGESTED_HOSTNAME="${DISTRICT}-pi-b"
    fi
fi

if [[ -n "${SUGGESTED_HOSTNAME}" ]]; then
    muted "Suggested: ${SUGGESTED_HOSTNAME}  (based on existing Pis in this district)"
    placeholder="blank → ${SUGGESTED_HOSTNAME}"
else
    muted "Blank → auto: <district>-pi-<serial8>"
    placeholder="e.g. oakridge-pi-a"
fi
HOSTNAME_HINT=$(gum input --prompt "› " --placeholder "${placeholder}")
[[ -z "${HOSTNAME_HINT}" && -n "${SUGGESTED_HOSTNAME}" ]] && HOSTNAME_HINT="${SUGGESTED_HOSTNAME}"

section "Auth key"
if [[ -n "${DCS_AUTHKEY:-}" ]]; then
    AUTHKEY="${DCS_AUTHKEY}"
    muted "using auth key from \$DCS_AUTHKEY"
else
    muted "Minting a one-hour tag-scoped key for tag:pi-${DISTRICT}…"
    MINT_RC=0
    MINT_OUT=$(dcs-mint-key "pi-${DISTRICT}" 2>&1) || MINT_RC=$?
    if [[ "${MINT_RC}" -eq 0 && "${MINT_OUT}" == tskey-auth-* ]]; then
        AUTHKEY="${MINT_OUT}"
        ok "auth key minted"
    else
        err "auto-mint failed:"
        printf '  %s\n' "${MINT_OUT}"
        muted "Common causes:"
        muted "  • tag:pi-${DISTRICT} not declared in ACL tagOwners / autoApprovers"
        muted "  • OAuth client missing the auth_keys:write scope"
        if gum confirm "Paste a pre-minted auth key instead?"; then
            AUTHKEY=$(gum input --password --prompt "› ")
            [[ -n "${AUTHKEY}" ]] || { err "authkey required"; exit 1; }
        else
            err "aborted"
            exit 1
        fi
    fi
fi

# Summary
ROUTES_DISPLAY=$(printf '%s, ' "${CIDRS[@]}"); ROUTES_DISPLAY=${ROUTES_DISPLAY%, }
printf '\n'
gum style --border normal --border-foreground "${C_MUTED}" --padding "0 2" \
    "$(gum style --bold --foreground "${C_INFO}" 'Review')" \
    "" \
    "  District    ${DISTRICT}" \
    "  Subnets     ${ROUTES_DISPLAY}" \
    "  Hostname    ${HOSTNAME_HINT:-<auto: ${DISTRICT}-pi-XXXX>}" \
    "  Authkey     ${AUTHKEY:0:12}… (hidden)"

gum confirm "Write config and start enrollment?" || { warn "aborted"; exit 1; }

# Build JSON array from CIDRS (may be empty → dcs-enroll will auto-detect)
if [[ ${#CIDRS[@]} -gt 0 ]]; then
    ROUTES_JSON=$(printf '%s\n' "${CIDRS[@]}" | jq -R . | jq -s .)
else
    ROUTES_JSON='[]'
fi
jq -n \
    --arg authkey  "${AUTHKEY}" \
    --arg district "${DISTRICT}" \
    --argjson routes "${ROUTES_JSON}" \
    --arg hostname "${HOSTNAME_HINT}" \
    '{authkey:$authkey, district:$district, advertise_routes:$routes}
     + (if $hostname == "" then {} else {hostname:$hostname} end)' \
    > "${ENROLL_CONFIG}"
chmod 0600 "${ENROLL_CONFIG}"

ok "Config written to ${ENROLL_CONFIG}"

systemctl reset-failed first-boot.service 2>/dev/null || true
systemctl start --no-block first-boot.service

gum spin --spinner dot --spinner.foreground "${C_BRAND}" \
    --title "Enrolling (Pi will reboot on success)…" -- sleep 6

section "Enrollment log (last 40 lines)"
journalctl -u first-boot.service -n 40 --no-pager || true

# Pull the most recent TAGCHECK result out of the journal.
tagcheck_line=$(journalctl -u first-boot.service -n 80 --no-pager 2>/dev/null \
    | grep -E 'TAGCHECK (PASS|FAIL|SKIPPED)' | tail -1 || true)

section "Tag validation"
case "${tagcheck_line}" in
    *"TAGCHECK PASS"*)
        ok "Node is tagged for district ${DISTRICT}"
        ;;
    *"TAGCHECK FAIL"*)
        err "Tag check FAILED"
        printf '  %s\n' "${tagcheck_line#*TAGCHECK FAIL: }"
        warn "The Pi is on the tailnet but in the wrong (or no) tag scope."
        muted "Fix:"
        muted "  1. In the Tailscale admin, remove this node"
        muted "  2. Mint a new authkey with Tags = tag:pi-${DISTRICT}"
        muted "  3. Run \`sudo dcs reset\` then \`sudo dcs-setup\`"
        ;;
    *"TAGCHECK SKIPPED"*)
        muted "(skipped — dry run)"
        ;;
    *)
        muted "(no tag check result found in journal yet — check \`sudo dcs status\` after reboot)"
        ;;
esac

gum style \
    --border double --border-foreground "${C_OK}" \
    --padding "1 3" --margin "1 0" \
    --foreground "${C_OK}" --bold \
    "✓ Setup complete" \
    "" \
    "If you saw 'enrollment complete' above, the Pi will reboot shortly." \
    "Reconnect via the Tailscale admin panel or the new hostname." \
    "Ready for \`sudo poweroff\` and shipment once back online."
