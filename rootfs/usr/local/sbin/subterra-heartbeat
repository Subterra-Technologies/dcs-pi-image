#!/usr/bin/env bash
# Ping at least one Zabbix VM peer's tunnel IP to log tunnel health.
# Reads peers from /var/lib/subterra/enrollment.json.
set -euo pipefail

STATE_DIR="${SUBTERRA_STATE_DIR:-/var/lib/subterra}"
META="${STATE_DIR}/enrollment.json"

[[ -s "${META}" ]] || { echo "heartbeat: no enrollment.json yet" >&2; exit 0; }

mapfile -t TARGETS < <(jq -r '.peers[].tunnel_ip | sub("/.*"; "")' "${META}")
(( ${#TARGETS[@]} > 0 )) || { echo "heartbeat: no peers" >&2; exit 1; }

ok=0
for ip in "${TARGETS[@]}"; do
    if ping -c1 -W2 "${ip}" >/dev/null 2>&1; then
        echo "heartbeat ok ${ip}"
        ok=1
    else
        echo "heartbeat FAIL ${ip}" >&2
    fi
done

(( ok == 1 )) || exit 1
