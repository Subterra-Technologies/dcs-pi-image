#!/usr/bin/env bash
# dcs: admin TUI for a deployed DCS Pi.
#
# Usage:
#   dcs               → interactive menu
#   dcs status        → current state summary
#   dcs stats         → uptime, peers, NAT
#   dcs logs          → pick a service, tail journal
#   dcs routes        → view/edit advertised subnets
#   dcs preflight     → verify the school's egress permits Tailscale
#   dcs reconfigure   → wipe state + re-run dcs-setup
#   dcs reset         → tailnet logout + wipe local enrollment state
#   dcs update        → pull latest dcs scripts + units from the repo
#   dcs help          → this text

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
    exec sudo --preserve-env=SSH_CONNECTION "$0" "$@"
fi

STATE_DIR=/var/lib/dcs
ENROLL_META="${STATE_DIR}/enrollment.json"
ENROLL_SENTINEL="${STATE_DIR}/enrolled"

# Palette
C_BRAND=99      # purple
C_OK=42         # green
C_WARN=214      # amber
C_ERR=196       # red
C_MUTED=245     # gray
C_INFO=75       # cyan

header()  { gum style --border double --border-foreground "${C_BRAND}" --padding "1 3" --margin "1 0" --foreground "${C_BRAND}" --bold "$@"; }
section() { gum style --foreground "${C_BRAND}" --bold --margin "1 0 0 0" "▸ $*"; }
ok()      { gum style --foreground "${C_OK}"    "✓ $*"; }
warn()    { gum style --foreground "${C_WARN}"  "⚠ $*"; }
err()     { gum style --foreground "${C_ERR}"   "✗ $*"; }
muted()   { gum style --foreground "${C_MUTED}" "$*"; }
kv()      { printf '  %-14s %s\n' "$1" "$2"; }

is_enrolled() { [[ -f "${ENROLL_SENTINEL}" ]]; }

meta() {
    [[ -f "${ENROLL_META}" ]] || { echo ""; return; }
    jq -r --arg k "$1" '.[$k] // ""' "${ENROLL_META}"
}

tailnet_ip()     { tailscale ip -4 2>/dev/null | head -1 || true; }
tailnet_state()  { tailscale status --json 2>/dev/null | jq -r '.BackendState // "Unknown"'; }
tailnet_online() { [[ "$(tailnet_state)" == "Running" ]]; }

advertised_routes_csv() {
    # Prefs is the source of truth for what this node advertises.
    tailscale debug prefs 2>/dev/null \
        | jq -r '.AdvertiseRoutes // [] | join(",")' 2>/dev/null || true
}

peer_counts() {
    local j
    j=$(tailscale status --json 2>/dev/null || echo '{}')
    local total online
    total=$(jq '[.Peer // {} | to_entries[].value] | length' <<<"${j}" 2>/dev/null || echo 0)
    online=$(jq '[.Peer // {} | to_entries[].value | select(.Online==true)] | length' <<<"${j}" 2>/dev/null || echo 0)
    echo "${online}/${total}"
}

cmd_status() {
    header "◆ SCHOOL SIDE ◆  DCS Pi — Status"
    local enr district hostname routes tn_ip tn_state_s peers
    if is_enrolled; then
        enr="$(gum style --foreground "${C_OK}" "✓ yes")  $(muted "since $(meta enrolled_at)")"
    else
        enr="$(gum style --foreground "${C_ERR}" "✗ no") $(muted "(run 'dcs-setup')")"
    fi
    district=$(meta district)
    hostname=$(meta hostname)
    routes=$(advertised_routes_csv)
    [[ -z "${routes}" ]] && routes=$(meta advertise_routes)
    tn_ip=$(tailnet_ip)
    if tailnet_online; then
        tn_state_s="$(gum style --foreground "${C_OK}" "✓ online (Running)")"
    else
        tn_state_s="$(gum style --foreground "${C_ERR}" "✗ $(tailnet_state)")"
    fi
    peers=$(peer_counts)

    local version
    version=$(cat "${STATE_DIR}/installed-sha" 2>/dev/null || echo "")
    kv "Enrolled"   "${enr}"
    kv "District"   "${district:-<unset>}"
    kv "Hostname"   "${hostname:-$(hostname)}"
    kv "Routes"     "${routes:-<none>}"
    kv "Tailnet IP" "${tn_ip:-<none>}"
    kv "Tailnet"    "${tn_state_s}"
    kv "Peers"      "${peers} (online/total)"
    kv "Version"    "${version:0:7}${version:+  (dcs update to refresh)}"
}

cmd_stats() {
    header "◆ SCHOOL SIDE ◆  DCS Pi — Stats"
    local up load mem disk zabbix temp
    up=$(uptime -p | sed 's/^up //')
    load=$(awk '{print $1", "$2", "$3}' /proc/loadavg)
    mem=$(free -h --si | awk '/^Mem:/ {print $3" / "$2" used"}')
    disk=$(df -h --output=used,size,pcent / | tail -1 | awk '{print $1" / "$2" ("$3")"}')
    temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null | awk '{printf "%.1f°C\n", $1/1000}' || echo "n/a")
    if systemctl is-active --quiet zabbix-proxy 2>/dev/null; then
        zabbix="$(gum style --foreground "${C_OK}" "✓ running")"
    elif systemctl list-unit-files zabbix-proxy.service 2>/dev/null | grep -q zabbix; then
        zabbix="$(gum style --foreground "${C_ERR}" "✗ not running")"
    else
        zabbix="$(muted "not installed")"
    fi

    kv "Uptime"        "${up}"
    kv "Load avg"      "${load}"
    kv "Memory"        "${mem}"
    kv "Disk (/)"      "${disk}"
    kv "CPU temp"      "${temp}"
    kv "Zabbix proxy"  "${zabbix}"
    kv "Peers"         "$(peer_counts) (online/total)"

    section "Tailscale netcheck"
    if tailnet_online; then
        local out
        out=$(mktemp)
        gum spin --spinner dot --spinner.foreground "${C_BRAND}" \
            --title "probing network (takes ~5s)…" -- \
            bash -c "tailscale netcheck > '${out}' 2>&1 || true"
        sed 's/^/  /' "${out}" | head -25
        rm -f "${out}"
    else
        muted "  tailnet offline — skipping"
    fi
}

cmd_logs() {
    local svc unit
    svc=$(gum choose --cursor "› " --header "Which service?" \
        "Enrollment (first-boot.service)" \
        "Tailscale (tailscaled)" \
        "Heartbeat (dcs-heartbeat.service)" \
        "System journal")
    case "${svc}" in
        Enrollment*) unit=first-boot.service ;;
        Tailscale*)  unit=tailscaled ;;
        Heartbeat*)  unit=dcs-heartbeat.service ;;
        System*)     unit="" ;;
        *) exit 0 ;;
    esac
    section "${svc} — last 50 entries"
    if [[ -n "${unit}" ]]; then
        journalctl -u "${unit}" -n 50 --no-pager 2>&1
    else
        journalctl -n 50 --no-pager
    fi
}

cmd_routes() {
    header "◆ SCHOOL SIDE ◆  DCS Pi — Advertised routes"
    if ! command -v tailscale >/dev/null; then
        err "tailscale not installed"; exit 1
    fi

    local csv
    csv=$(advertised_routes_csv)
    local -a current=()
    if [[ -n "${csv}" ]]; then
        IFS=',' read -ra current <<<"${csv}"
    fi

    if [[ ${#current[@]} -eq 0 ]]; then
        muted "No advertised routes."
    else
        muted "Current:"
        for r in "${current[@]}"; do
            printf '    • %s\n' "${r}"
        done
    fi

    local action pick cidr
    action=$(gum choose --cursor "› " "Add a CIDR" "Remove a CIDR" "Cancel")
    local -a new=()
    case "${action}" in
        "Add a CIDR")
            cidr=$(gum input --prompt "› " --placeholder "e.g. 10.42.0.0/24")
            [[ "${cidr}" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]] \
                || { err "invalid CIDR"; exit 1; }
            new=("${current[@]}" "${cidr}")
            ;;
        "Remove a CIDR")
            [[ ${#current[@]} -gt 0 ]] || { warn "nothing to remove"; exit 0; }
            pick=$(gum choose --cursor "› " "${current[@]}")
            for r in "${current[@]}"; do
                [[ "${r}" != "${pick}" ]] && new+=("${r}")
            done
            ;;
        *) exit 0 ;;
    esac

    local new_csv
    new_csv=$(IFS=','; echo "${new[*]}")
    gum confirm "Apply advertise-routes=${new_csv:-<none>}?" || exit 0
    tailscale set --advertise-routes="${new_csv}"
    ok "Set. Approve in the Tailscale admin console if any CIDRs are new."
}

cmd_reconfigure() {
    warn "Reconfigure wipes local enrollment and re-runs dcs-setup."
    gum confirm "Proceed?" || exit 0
    exec /usr/local/sbin/dcs-setup
}

cmd_preflight() {
    if [[ ! -x /usr/local/sbin/dcs-preflight ]]; then
        err "/usr/local/sbin/dcs-preflight not found — run 'sudo dcs update' first"
        exit 1
    fi
    exec /usr/local/sbin/dcs-preflight "$@"
}

caller_ssh_connection() {
    if [[ -n "${SSH_CONNECTION:-}" ]]; then
        printf '%s' "${SSH_CONNECTION}"
        return
    fi
    # sudo strips SSH_CONNECTION by default; read our parent's environ.
    if [[ -r "/proc/$PPID/environ" ]]; then
        tr '\0' '\n' < "/proc/$PPID/environ" 2>/dev/null \
            | awk -F= '$1=="SSH_CONNECTION"{print substr($0, length($1)+2); exit}'
    fi
}

is_tailscale_session() {
    local conn server_ip ts_ip4 ts_ip6
    conn=$(caller_ssh_connection)
    [[ -n "${conn}" ]] || return 1
    server_ip=$(awk '{print $3}' <<<"${conn}")
    ts_ip4=$(tailscale ip -4 2>/dev/null | head -1 || true)
    ts_ip6=$(tailscale ip -6 2>/dev/null | head -1 || true)
    [[ -n "${ts_ip4}" && "${server_ip}" == "${ts_ip4}" ]] && return 0
    [[ -n "${ts_ip6}" && "${server_ip}" == "${ts_ip6}" ]] && return 0
    return 1
}

cmd_reset() {
    local force=0
    [[ "${1:-}" == "--force" ]] && force=1

    if [[ ${force} -eq 0 ]] && is_tailscale_session; then
        err "Refusing to reset: you're connected over Tailscale SSH."
        muted "Reset runs 'tailscale logout', which cuts this session immediately"
        muted "and wipes local enrollment. You'd need LAN or physical access to"
        muted "this Pi to re-enroll."
        echo
        muted "To swap district/authkey without wiping state, use:"
        muted "  sudo dcs reconfigure"
        echo
        muted "To proceed anyway (you've verified you have another way in):"
        muted "  sudo dcs reset --force"
        exit 1
    fi

    err "Reset logs out of the tailnet and wipes local enrollment state."
    gum confirm "Proceed?" || exit 0
    tailscale logout 2>/dev/null || true
    rm -f "${ENROLL_SENTINEL}" "${ENROLL_META}"
    ok "Reset complete. Run 'dcs-setup' to re-enroll."
}

cmd_update() {
    local repo_url="${DCS_REPO_URL:-https://github.com/Subterra-Technologies/dcs-pi-image}"
    local repo_ref="${DCS_REPO_REF:-main}"

    header "◆ SCHOOL SIDE ◆  DCS Pi — Update" \
        "" \
        "Pulls the latest dcs scripts + systemd units from ${repo_ref}." \
        "Does NOT re-run enrollment or touch /etc/dcs.conf."

    if ! command -v git >/dev/null 2>&1; then
        muted "installing git (required to fetch updates)…"
        DEBIAN_FRONTEND=noninteractive apt-get update -qq
        DEBIAN_FRONTEND=noninteractive apt-get install -y -qq git
    fi

    local stage
    stage=$(mktemp -d -t dcs-update.XXXXXX)
    # shellcheck disable=SC2064
    trap "rm -rf '${stage}'" RETURN

    section "Fetching"
    muted "repo: ${repo_url}  ref: ${repo_ref}"
    if ! git clone --quiet --depth 50 --branch "${repo_ref}" \
            "${repo_url}" "${stage}/repo" 2>/dev/null
    then
        err "clone failed — check network connectivity and repo URL"
        return 1
    fi

    local new_sha cur_sha
    new_sha=$(git -C "${stage}/repo" rev-parse HEAD)
    cur_sha=$(cat "${STATE_DIR}/installed-sha" 2>/dev/null || echo "")

    section "Versions"
    kv "Installed" "${cur_sha:-unknown}"
    kv "Latest"    "${new_sha}"

    if [[ "${cur_sha}" == "${new_sha}" ]]; then
        ok "already at the latest version"
        return 0
    fi

    # Best-effort changelog: only shows if the installed SHA is within the
    # shallow clone's history. Older than that → we just skip the log.
    if [[ -n "${cur_sha}" ]] \
        && git -C "${stage}/repo" cat-file -e "${cur_sha}^{commit}" 2>/dev/null
    then
        section "Changes since installed version"
        git -C "${stage}/repo" log --oneline --no-merges \
            "${cur_sha}..${new_sha}" | head -20
    fi

    printf '\n'
    gum confirm "Apply update?" || { warn "aborted"; return 0; }

    section "Installing"
    local installed_scripts=0 installed_units=0 f name
    for f in "${stage}/repo/rootfs/usr/local/sbin/"*; do
        [[ -f "${f}" ]] || continue
        name=$(basename "${f}")
        case "${name}" in .*|*~|*.swp) continue ;; esac
        install -m 0755 "${f}" "/usr/local/sbin/${name}"
        installed_scripts=$((installed_scripts + 1))
    done
    ok "${installed_scripts} scripts installed to /usr/local/sbin"

    for f in "${stage}/repo/rootfs/etc/systemd/system/"*; do
        [[ -f "${f}" ]] || continue
        name=$(basename "${f}")
        case "${name}" in .*|*~|*.swp) continue ;; esac
        install -m 0644 "${f}" "/etc/systemd/system/${name}"
        installed_units=$((installed_units + 1))
    done
    ok "${installed_units} units installed to /etc/systemd/system"

    local installed_sysctl=0 sysctl_changed=0
    for f in "${stage}/repo/rootfs/etc/sysctl.d/"*; do
        [[ -f "${f}" ]] || continue
        name=$(basename "${f}")
        case "${name}" in .*|*~|*.swp) continue ;; esac
        if ! cmp -s "${f}" "/etc/sysctl.d/${name}" 2>/dev/null; then
            sysctl_changed=1
        fi
        install -m 0644 "${f}" "/etc/sysctl.d/${name}"
        installed_sysctl=$((installed_sysctl + 1))
    done
    ok "${installed_sysctl} sysctl drop-ins installed to /etc/sysctl.d"
    if [[ "${sysctl_changed}" == "1" ]]; then
        sysctl --system >/dev/null
        ok "sysctl reloaded"
    fi

    systemctl daemon-reload
    ok "systemd reloaded"

    if systemctl is-active --quiet dcs-heartbeat.timer 2>/dev/null; then
        systemctl restart dcs-heartbeat.timer
        ok "dcs-heartbeat.timer restarted"
    fi

    mkdir -p "${STATE_DIR}"
    echo "${new_sha}" > "${STATE_DIR}/installed-sha"

    printf '\n'
    gum style --border double --border-foreground "${C_OK}" \
        --padding "1 3" --foreground "${C_OK}" --bold \
        "✓ Updated ${cur_sha:0:7} → ${new_sha:0:7}"
}

cmd_menu() {
    if ! is_enrolled; then
        header "◆ SCHOOL SIDE ◆  DCS Pi"
        warn "This Pi has no enrollment state yet."
        gum confirm "Run dcs-setup now?" || exit 0
        exec /usr/local/sbin/dcs-setup
    fi

    header "◆ SCHOOL SIDE ◆  DCS Pi — $(meta district) / $(meta hostname)"
    local choice
    choice=$(gum choose --cursor "› " --header "What would you like to do?" \
        "status       — current state summary" \
        "stats        — uptime, peers, NAT" \
        "logs         — recent journal entries" \
        "routes       — view/edit advertised subnets" \
        "preflight    — verify the school's egress permits Tailscale" \
        "update       — pull latest scripts + units from the repo" \
        "reconfigure  — re-run setup (new district/authkey)" \
        "reset        — wipe local enrollment state" \
        "exit")
    case "${choice}" in
        status*)      cmd_status ;;
        stats*)       cmd_stats ;;
        logs*)        cmd_logs ;;
        routes*)      cmd_routes ;;
        preflight*)   cmd_preflight ;;
        update*)      cmd_update ;;
        reconfigure*) cmd_reconfigure ;;
        reset*)       cmd_reset ;;
        *)            exit 0 ;;
    esac
}

usage() {
    cat <<EOF
dcs — admin TUI for a deployed DCS Pi

Usage:
  dcs [SUBCOMMAND]

Subcommands:
  status        current state summary
  stats         uptime, peers, NAT
  logs          pick a service, show recent journal entries
  routes        view or edit advertised subnets
  preflight     verify the school's egress permits Tailscale
                (--quiet for a single PASS/WARN/FAIL line, useful in CI)
  update        pull the newest dcs scripts + units from the repo
                (DCS_REPO_REF=<branch|tag|sha> to pin a version)
  reconfigure   wipe state + re-run dcs-setup
  reset         log out of tailnet + wipe local enrollment state
                (refuses over Tailscale SSH; use 'reset --force' to override)
  help          show this help

With no subcommand, opens an interactive menu.
EOF
}

case "${1:-menu}" in
    status)                cmd_status ;;
    stats)                 cmd_stats ;;
    logs)                  cmd_logs ;;
    routes)                cmd_routes ;;
    preflight)             shift; cmd_preflight "$@" ;;
    update)                cmd_update ;;
    reconfigure|reconfig)  cmd_reconfigure ;;
    reset)                 shift; cmd_reset "$@" ;;
    menu|'')               cmd_menu ;;
    -h|--help|help)        usage ;;
    *) err "unknown subcommand: $1"; usage; exit 2 ;;
esac
