#!/usr/bin/env bash
# dcs-preflight: verify the school's network permits the egress Tailscale needs.
#
# Run before final enrollment, ideally at the office on the school's intended
# WAN if possible, and again on-site at install. Catches the failure mode
# where a district's content filter / DPI firewall classifies Tailscale as a
# VPN and silently drops or throttles its traffic — the symptom otherwise is
# Zabbix going dark days later with no obvious cause.
#
# Exit codes:
#   0  all checks passed (or only soft warnings)
#   1  at least one warning that needs a human eye
#   2  hard failure — Tailscale will not work reliably from this network
#
# Usage:
#   dcs preflight                interactive, full output
#   dcs preflight --quiet        one-line PASS/WARN/FAIL summary only

set -euo pipefail

QUIET=0
[[ "${1:-}" == "--quiet" ]] && QUIET=1

C_BRAND=99
C_OK=42
C_WARN=214
C_ERR=196
C_MUTED=245

if command -v gum >/dev/null 2>&1 && [[ "${QUIET}" = "0" ]]; then
    header()  { gum style --border double --border-foreground "${C_BRAND}" --padding "1 3" --margin "1 0" --foreground "${C_BRAND}" --bold "$@"; }
    section() { gum style --foreground "${C_BRAND}" --bold --margin "1 0 0 0" "▸ $*"; }
    ok()      { gum style --foreground "${C_OK}"    "✓ $*"; }
    warn()    { gum style --foreground "${C_WARN}"  "⚠ $*"; }
    err()     { gum style --foreground "${C_ERR}"   "✗ $*"; }
    muted()   { gum style --foreground "${C_MUTED}" "$*"; }
else
    header()  { [[ "${QUIET}" = "0" ]] && printf '\n=== %s ===\n' "$*"; }
    section() { [[ "${QUIET}" = "0" ]] && printf '\n--- %s ---\n' "$*"; }
    ok()      { [[ "${QUIET}" = "0" ]] && printf '  [OK]   %s\n' "$*"; }
    warn()    { [[ "${QUIET}" = "0" ]] && printf '  [WARN] %s\n' "$*"; }
    err()     { [[ "${QUIET}" = "0" ]] && printf '  [FAIL] %s\n' "$*"; }
    muted()   { [[ "${QUIET}" = "0" ]] && printf '         %s\n' "$*"; }
fi

WARNS=0
FAILS=0
note_warn() { WARNS=$((WARNS + 1)); warn "$@"; }
note_fail() { FAILS=$((FAILS + 1)); err  "$@"; }

header "◆ SCHOOL SIDE ◆  DCS Pi — Network preflight"

# ---------------------------------------------------------------------------
section "1. Basic IP egress"
# ---------------------------------------------------------------------------
if ping -c 2 -W 3 -q 1.1.1.1 >/dev/null 2>&1; then
    ok "ICMP to 1.1.1.1 (Cloudflare) — reachable"
else
    note_warn "ICMP to 1.1.1.1 blocked — many school networks block ping; not always fatal"
fi
if ping -c 2 -W 3 -q 8.8.8.8 >/dev/null 2>&1; then
    ok "ICMP to 8.8.8.8 (Google) — reachable"
else
    note_warn "ICMP to 8.8.8.8 blocked"
fi

# ---------------------------------------------------------------------------
section "2. DNS resolution"
# ---------------------------------------------------------------------------
DERP_IP=""
if DERP_IP=$(getent ahostsv4 derp.tailscale.com 2>/dev/null | awk 'NR==1{print $1}') \
    && [[ -n "${DERP_IP}" ]]
then
    ok "derp.tailscale.com → ${DERP_IP}"
else
    note_fail "Cannot resolve derp.tailscale.com — check /etc/resolv.conf and upstream DNS"
fi
if getent ahostsv4 controlplane.tailscale.com >/dev/null 2>&1; then
    ok "controlplane.tailscale.com resolves"
else
    note_fail "Cannot resolve controlplane.tailscale.com — Tailscale coordination is unreachable"
fi

# ---------------------------------------------------------------------------
section "3. Tailscale netcheck (real UDP/DERP probes)"
# ---------------------------------------------------------------------------
NETCHECK=""
if command -v tailscale >/dev/null 2>&1; then
    NETCHECK=$(timeout 20 tailscale netcheck 2>/dev/null || true)
    if [[ -z "${NETCHECK}" ]]; then
        note_fail "tailscale netcheck produced no output — daemon not running?"
    else
        if echo "${NETCHECK}" | grep -qE '^\s*\* UDP: true'; then
            ok "UDP egress reaches Tailscale STUN"
        else
            note_fail "UDP blocked — Tailscale will be DERP-only and likely unstable"
            muted "      → ask network admin to allow UDP/3478 outbound + UDP to high ephemeral ports"
        fi

        nearest=$(echo "${NETCHECK}" | grep -E '^\s*\* Nearest DERP:' | head -1 \
                  | sed -E 's/.*Nearest DERP:\s*//; s/\s*$//')
        if [[ -z "${nearest}" || "${nearest}" == unknown* ]]; then
            note_fail "No DERP relay reachable — firewall is blocking Tailscale egress"
            muted "      → likely SNI/DPI block on *.tailscale.com or TCP/443 to DERP IPs"
        else
            ok "Nearest DERP: ${nearest}"
        fi

        if echo "${NETCHECK}" | grep -qE '^\s*\* MappingVariesByDestIP: true'; then
            note_warn "Hard NAT (MappingVariesByDestIP) — direct UDP path will be unreliable"
            muted "      → Tailscale will fall back to DERP relay; expect ~30ms latency"
        fi

        if echo "${NETCHECK}" | grep -qE '^\s*\* CaptivePortal: true'; then
            note_fail "Captive portal detected — network is intercepting HTTP"
        fi
    fi
else
    note_fail "tailscale binary not installed"
fi

# ---------------------------------------------------------------------------
section "4. SNI-based DPI detection"
# ---------------------------------------------------------------------------
# If TCP/443 fails by hostname but works by raw IP, the firewall is matching
# *.tailscale.com in the TLS Client Hello — classic anti-VPN DPI.
hostname_code=000
rawip_code=000
if command -v curl >/dev/null 2>&1; then
    hostname_code=$(curl -sS -o /dev/null --max-time 5 \
                       -w "%{http_code}" https://derp.tailscale.com/ 2>/dev/null || echo 000)
    if [[ -n "${DERP_IP}" ]]; then
        rawip_code=$(curl -sS -o /dev/null --max-time 5 -k \
                       -w "%{http_code}" "https://${DERP_IP}:443/" 2>/dev/null || echo 000)
    fi
    case "${hostname_code}_${rawip_code}" in
        000_000)
            note_fail "TCP/443 to DERP fails for both hostname and raw IP — egress blocked"
            muted "      → confirm outbound TCP/443 is allowed from this VLAN"
            ;;
        000_*)
            note_fail "TCP/443 hostname blocked, raw IP works — SNI-based DPI"
            muted "      → ask network admin to whitelist *.tailscale.com WITHOUT SSL inspection"
            ;;
        *_000)
            note_warn "Hostname succeeds but raw IP fails — unusual; investigate"
            ;;
        *)
            ok "TCP/443 to DERP reachable, no SNI-based blocking detected"
            ;;
    esac
else
    note_warn "curl not available — skipping SNI DPI check"
fi

# ---------------------------------------------------------------------------
section "5. Summary"
# ---------------------------------------------------------------------------
if [[ "${FAILS}" -eq 0 && "${WARNS}" -eq 0 ]]; then
    if [[ "${QUIET}" = "1" ]]; then echo "PASS"; fi
    ok "All checks passed — network permits Tailscale operation"
    exit 0
elif [[ "${FAILS}" -eq 0 ]]; then
    if [[ "${QUIET}" = "1" ]]; then echo "WARN ${WARNS}"; fi
    warn "${WARNS} warning(s) — Tailscale should still work but review the notes above"
    exit 1
else
    if [[ "${QUIET}" = "1" ]]; then echo "FAIL ${FAILS}/${WARNS}"; fi
    err "${FAILS} hard failure(s), ${WARNS} warning(s) — fix before deploying"
    muted ""
    muted "Hand this URL to the district's network admin:"
    muted "  https://github.com/Subterra-Technologies/dcs-pi-image/blob/main/docs/SCHOOL_IT_REQUIREMENTS.md"
    muted "It lists the exact firewall exemptions Tailscale needs."
    exit 2
fi
