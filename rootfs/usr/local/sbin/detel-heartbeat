#!/usr/bin/env bash
# Log tailnet connection health so journal shows when we flap.
set -euo pipefail

if ! command -v tailscale >/dev/null 2>&1; then
    echo "tailscale not installed yet" >&2
    exit 1
fi

STATUS_JSON="$(tailscale status --json 2>/dev/null || true)"
if [[ -z "${STATUS_JSON}" ]]; then
    echo "tailscale status unavailable" >&2
    exit 1
fi

backend="$(jq -r '.BackendState // "Unknown"' <<<"${STATUS_JSON}")"
self_ip="$(jq -r '.Self.TailscaleIPs[0] // "n/a"' <<<"${STATUS_JSON}")"

if [[ "${backend}" != "Running" ]]; then
    echo "heartbeat FAIL backend=${backend}" >&2
    exit 1
fi
echo "heartbeat ok backend=${backend} ip=${self_ip}"
