#!/usr/bin/env bash
# First-boot enrollment for a DCS Pi (Tailscale SaaS).
#
# Reads the pre-auth key from /boot/firmware/dcs-enroll.json, joins
# the Tailscale tailnet, advertises the district's school-LAN subnets.
# Routes auto-approve via the tailnet ACL's autoApprovers for the Pi's tag.
#
# The key must be tagged appropriately for the target district when
# created in the Tailscale admin console; the tag governs what routes the
# Pi can advertise and what district Zabbix can reach it.
set -euo pipefail

STATE_DIR="${DCS_STATE_DIR:-/var/lib/dcs}"
ENROLL_CONFIG="${DCS_ENROLL_CONFIG:-/boot/firmware/dcs-enroll.json}"
DRY_RUN="${DCS_DRY_RUN:-0}"

ENROLL_SENTINEL="${STATE_DIR}/enrolled"
ENROLL_META="${STATE_DIR}/enrollment.json"

LOG_TAG=dcs-enroll
log() { printf '%s: %s\n' "${LOG_TAG}" "$*" >&2; }
die() { log "FATAL: $*"; exit 1; }
priv() {
    if [[ "${DRY_RUN}" = "1" ]]; then
        log "DRY: $*"
    else
        "$@"
    fi
}

if [[ -f "${ENROLL_SENTINEL}" ]]; then
    log "already enrolled, exiting"
    exit 0
fi

mkdir -p "${STATE_DIR}"

[[ -f "${ENROLL_CONFIG}" ]] || die "no enrollment config at ${ENROLL_CONFIG}"

AUTHKEY="$(jq -r '.authkey // empty' "${ENROLL_CONFIG}")"
DISTRICT="$(jq -r '.district // empty' "${ENROLL_CONFIG}")"
ADVERTISE_ROUTES="$(jq -r '.advertise_routes // [] | join(",")' "${ENROLL_CONFIG}")"
HOSTNAME_HINT="$(jq -r '.hostname // empty' "${ENROLL_CONFIG}")"

[[ -n "${AUTHKEY}" ]]  || die "authkey missing from ${ENROLL_CONFIG}"
[[ -n "${DISTRICT}" ]] || die "district missing from ${ENROLL_CONFIG}"

# Sanitize district to a valid DNS label (defense-in-depth: the TUI already
# does this, but a hand-edited JSON could still contain spaces/caps/etc.).
DISTRICT_CLEAN="$(printf '%s' "${DISTRICT,,}" \
    | tr ' _' '--' \
    | sed -E 's/[^a-z0-9-]//g; s/-+/-/g; s/^-+|-+$//g')"
if [[ -z "${DISTRICT_CLEAN}" ]]; then
    die "district '${DISTRICT}' reduces to empty slug after sanitizing"
fi
if [[ "${DISTRICT_CLEAN}" != "${DISTRICT}" ]]; then
    log "sanitized district: '${DISTRICT}' → '${DISTRICT_CLEAN}'"
fi
DISTRICT="${DISTRICT_CLEAN}"

# Auto-detect the primary subnet as a *fallback* when ops didn't pre-seed
# any advertise_routes. Never merge into an explicit list — provisioning
# in the office must not silently add the office LAN when the operator
# pre-declared the school's CIDR.
detect_primary_subnet() {
    local iface cidr
    iface="$(ip -o -4 route show default 2>/dev/null | awk '{print $5; exit}')"
    [[ -n "${iface}" ]] || return 1
    cidr="$(ip -o -4 addr show dev "${iface}" 2>/dev/null | awk '{print $4; exit}')"
    [[ -n "${cidr}" ]] || return 1
    python3 -c "
import ipaddress, sys
print(ipaddress.ip_interface(sys.argv[1]).network.with_prefixlen)
" "${cidr}"
}

if [[ -z "${ADVERTISE_ROUTES}" ]]; then
    if PRIMARY="$(detect_primary_subnet)"; then
        log "no explicit routes in config — using auto-detected primary subnet: ${PRIMARY}"
        ADVERTISE_ROUTES="${PRIMARY}"
    else
        log "no explicit routes and auto-detect failed — advertising nothing"
    fi
else
    log "using explicit routes from config (auto-detect skipped)"
fi
log "routes to advertise: ${ADVERTISE_ROUTES:-<none>}"

# Hostname = explicit hint, else <district>-<short-serial>
if [[ -z "${HOSTNAME_HINT}" ]]; then
    if [[ -n "${DCS_SERIAL:-}" ]]; then
        SERIAL_SHORT="${DCS_SERIAL}"
    elif [[ -r /sys/firmware/devicetree/base/serial-number ]]; then
        SERIAL_SHORT="$(tr -d '\0' < /sys/firmware/devicetree/base/serial-number | tail -c 8)"
    else
        SERIAL_SHORT="$(hostname)"
    fi
    HOSTNAME_NEW="${DISTRICT}-pi-${SERIAL_SHORT}"
else
    HOSTNAME_NEW="${HOSTNAME_HINT}"
fi
priv hostnamectl set-hostname "${HOSTNAME_NEW}"

args=(
    up
    --authkey "${AUTHKEY}"
    --hostname "${HOSTNAME_NEW}"
    --ssh
    --accept-dns=false
    --reset
)
if [[ -n "${ADVERTISE_ROUTES}" ]]; then
    args+=(--advertise-routes "${ADVERTISE_ROUTES}")
fi

log "joining tailnet (Tailscale SaaS)"
priv tailscale "${args[@]}"

# Sanity-check that the authkey was tag-scoped for this district.
# Result is logged with TAGCHECK {PASS|FAIL|SKIPPED} so dcs-setup can
# surface it prominently. We never block enrollment on a tag mismatch —
# the Pi is already on the tailnet — but a FAIL tells ops to revoke the
# key, mint a properly-scoped one, and rerun.
EXPECTED_TAG="tag:pi-${DISTRICT}"
if [[ "${DRY_RUN}" = "1" ]]; then
    log "TAGCHECK SKIPPED (dry run; expected ${EXPECTED_TAG})"
else
    sleep 2  # let tailscaled settle after `up`
    ACTUAL_TAGS="$(tailscale status --json 2>/dev/null | jq -r '(.Self.Tags // []) | join(",")' 2>/dev/null || echo "")"
    if [[ -z "${ACTUAL_TAGS}" ]]; then
        log "TAGCHECK FAIL: node has no tags; authkey was not tag-scoped (expected ${EXPECTED_TAG})"
    elif [[ ",${ACTUAL_TAGS}," = *",${EXPECTED_TAG},"* ]]; then
        log "TAGCHECK PASS: ${ACTUAL_TAGS}"
    else
        log "TAGCHECK FAIL: expected ${EXPECTED_TAG}; got ${ACTUAL_TAGS}"
    fi
fi

# Record what we did for humans reading the Pi later.
jq -n \
    --arg hostname "${HOSTNAME_NEW}" \
    --arg district "${DISTRICT}" \
    --arg routes "${ADVERTISE_ROUTES}" \
    --arg enrolled_at "$(date -u +%FT%TZ)" \
    '{hostname:$hostname, district:$district,
      advertise_routes:$routes, enrolled_at:$enrolled_at}' \
    > "${ENROLL_META}"

touch "${ENROLL_SENTINEL}"
rm -f "${ENROLL_CONFIG}"
sync

log "enrollment complete for ${HOSTNAME_NEW}"

if [[ "${DRY_RUN}" != "1" ]]; then
    log "rebooting to verify clean boot"
    systemctl reboot
fi
