#!/usr/bin/env bash
# dcs-mint-key: mint a tag-scoped one-hour pre-auth key via Tailscale API.
#
# Usage:
#   dcs-mint-key TAG       # e.g. dcs-mint-key zabbix-oakridge
#                          # "tag:" prefix is added if missing
#
# Prints the minted authkey (tskey-auth-...) to stdout on success.
# Exits 0 on success, 1 on any failure.
#
# Reads OAuth creds from /etc/dcs.conf (or $DCS_CONF):
#   DCS_TS_OAUTH_CLIENT_ID=...
#   DCS_TS_OAUTH_CLIENT_SECRET=...
#   DCS_TS_TAILNET=-            # "-" = the OAuth client's own tailnet
#
# Required OAuth scope: auth_keys (Write), with the target tags selected on
# the OAuth client. (The same client can also hold devices:core Read for
# dcs-districts / dcs-query.)

set -euo pipefail

TAG="${1:?usage: dcs-mint-key TAG}"
TAG="${TAG#tag:}"
FULL_TAG="tag:${TAG}"

CONF="${DCS_CONF:-/etc/dcs.conf}"
if [[ -f "${CONF}" ]]; then
    # shellcheck disable=SC1090
    . "${CONF}"
fi

if [[ -z "${DCS_TS_OAUTH_CLIENT_ID:-}" || -z "${DCS_TS_OAUTH_CLIENT_SECRET:-}" ]]; then
    echo "dcs-mint-key: OAuth creds not set (expected in ${CONF})" >&2
    exit 1
fi
TAILNET="${DCS_TS_TAILNET:--}"

# Mint an OAuth access token. We intentionally don't use `curl -f` here —
# on HTTP errors we still want the response body (Tailscale returns JSON
# with a useful `message` field) so we can show it to the operator.
TOKEN_RESPONSE=$(curl -sS -X POST https://api.tailscale.com/api/v2/oauth/token \
    -d "client_id=${DCS_TS_OAUTH_CLIENT_ID}" \
    -d "client_secret=${DCS_TS_OAUTH_CLIENT_SECRET}" \
    -d "grant_type=client_credentials" \
    -w '\n%{http_code}' 2>&1 || true)
TOKEN_HTTP=${TOKEN_RESPONSE##*$'\n'}
TOKEN_BODY=${TOKEN_RESPONSE%$'\n'*}
TOKEN=$(printf '%s' "${TOKEN_BODY}" | jq -r '.access_token // empty' 2>/dev/null || true)

if [[ -z "${TOKEN}" ]]; then
    echo "dcs-mint-key: OAuth token request failed (HTTP ${TOKEN_HTTP:-?})" >&2
    TOKEN_MSG=$(printf '%s' "${TOKEN_BODY}" | jq -r '.error_description // .error // empty' 2>/dev/null || true)
    if [[ -n "${TOKEN_MSG}" ]]; then
        echo "  ${TOKEN_MSG}" >&2
    elif [[ -n "${TOKEN_BODY}" ]]; then
        printf '  %s\n' "${TOKEN_BODY}" >&2
    fi
    exit 1
fi

BODY=$(jq -n \
    --arg tag  "${FULL_TAG}" \
    --arg desc "dcs-setup auto-mint for ${FULL_TAG}" \
    '{
      capabilities: {
        devices: {
          create: {
            reusable: false,
            ephemeral: false,
            preauthorized: true,
            tags: [$tag]
          }
        }
      },
      expirySeconds: 3600,
      description: $desc
    }')

RESPONSE=$(curl -sS -X POST \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Type: application/json" \
    -d "${BODY}" \
    -w '\n%{http_code}' \
    "https://api.tailscale.com/api/v2/tailnet/${TAILNET}/keys" 2>&1 || true)
HTTP=${RESPONSE##*$'\n'}
RESPONSE_BODY=${RESPONSE%$'\n'*}

if [[ "${HTTP}" != "200" ]]; then
    echo "dcs-mint-key: mint request failed (HTTP ${HTTP:-?}) for ${FULL_TAG}" >&2
    API_MSG=$(printf '%s' "${RESPONSE_BODY}" | jq -r '.message // empty' 2>/dev/null || true)
    if [[ -n "${API_MSG}" ]]; then
        echo "  ${API_MSG}" >&2
    elif [[ -n "${RESPONSE_BODY}" ]]; then
        printf '  %s\n' "${RESPONSE_BODY}" >&2
    fi
    echo >&2
    echo "Check that the OAuth client at" >&2
    echo "  https://login.tailscale.com/admin/settings/trust-credentials" >&2
    echo "has the auth_keys scope with Write, and that ${FULL_TAG} is in the" >&2
    echo "tag list picked on that client (even 'all' scope requires per-tag" >&2
    echo "selection for auth_keys)." >&2
    exit 1
fi

KEY=$(printf '%s' "${RESPONSE_BODY}" | jq -r '.key // empty' 2>/dev/null || true)
if [[ -z "${KEY}" ]]; then
    echo "dcs-mint-key: API returned HTTP 200 but no .key field:" >&2
    printf '  %s\n' "${RESPONSE_BODY}" >&2
    exit 1
fi

printf '%s\n' "${KEY}"
